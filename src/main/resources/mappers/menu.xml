<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.lasttable.menu.repository.MenuMapper">

    <!-- 모든 메뉴 조회 -->
    <select id="findAll" resultType="com.ssafy.lasttable.menu.entity.Menu">
        SELECT *
        FROM menu
        ORDER BY menu_id
    </select>

    <!-- 메뉴 ID로 조회 -->
    <select id="findById" resultType="com.ssafy.lasttable.menu.entity.Menu">
        SELECT *
        FROM menu
        WHERE menu_id = #{menuId}
    </select>
    
</mapper>
